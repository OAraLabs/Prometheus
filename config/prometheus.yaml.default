# Prometheus configuration — reference defaults
# Copy to config/prometheus.yaml and customize.
# config/prometheus.yaml is gitignored — your secrets stay local.

system:
  name: "Prometheus"
  version: "0.1.0"

# Layer 1 Bootstrap — identity files loaded into every system prompt
bootstrap:
  load_soul: true       # ~/.prometheus/SOUL.md
  load_agents: true     # ~/.prometheus/AGENTS.md

model:
  provider: "llama_cpp"             # llama_cpp, ollama, openai, anthropic, gemini, xai
  base_url: "http://localhost:8080" # Inference server URL
  model: ""                         # Auto-detected from server if blank
  grammar_enforcement: true             # GBNF constrained decoding for llama.cpp tool calls
  max_tool_iterations: 25               # Max tool calls per user message before hard stop (local/llama)
  max_tool_iterations_cloud: 50         # Separate cap for cloud (tier=off): Claude plans multi-step sequences local models wouldn't
  fallback_provider: "ollama"
  fallback_url: "http://localhost:11434"

context:
  effective_limit: 24000
  compression_trigger: 0.75
  tool_result_max: 4000
  tool_results_turn_budget: 8000            # max tokens across all results per turn
  reserved_output: 2000
  fresh_tail_count: 32
  microcompact_after_turns: 3               # compact tool results older than N turns
  microcompact_keep_chars: 200
  microcompact_keep_chars_no_lcm: 500

tools:
  deferred_loading:
    enabled: false                          # all tool schemas in prompt by default
    always_loaded: [bash, read_file, write_file, edit_file, grep, glob, tool_search]
    mcp_always_deferred: true
    search_mcp: true

adapter:
  adaptive_strictness: false                # auto-tune per-tool strictness from telemetry
  strictness_window: 100
  strictness_threshold: 0.8

security:
  permission_mode: "default"
  workspace_root: "~"
  denied_commands:
    - "rm -rf /"
    - "rm -rf ~"
    - "DROP TABLE"
    - "mkfs"
  denied_paths:
    - "/etc"
    - "/sys"
    - "/boot"
    - "~/.ssh"
    - "config/prometheus.yaml"
  audit:
    enabled: true
    retention_days: 30
  exfiltration:
    enabled: true
  approval_queue:
    enabled: false
    timeout_seconds: 300

infrastructure:
  archive_enabled: true
  telemetry_enabled: true

gateway:
  telegram_enabled: false
  telegram_token: ""                # Set via PROMETHEUS_TELEGRAM_TOKEN env var
  allowed_chat_ids: []
  proxy_url: null
  heartbeat_interval: 30
  cron_enabled: true
  media:
    max_file_size_mb: 20
    cache_dir: "~/.prometheus/cache/media"
  rate_limits:
    messages_per_minute: 30
    media_downloads_per_minute: 10

whisper:
  enabled: false
  model: "base"
  device: "auto"
  language: "en"

model_router:
  enabled: false

# Sprint 22 GRAFT-ROUTER-WIRE Phase 4 — direct-mode provider overrides.
#
# Lets you switch a single Telegram (or Slack) chat to a different cloud
# provider on the fly:
#   /claude   — route this chat through Anthropic Claude
#   /gpt      — OpenAI GPT
#   /gemini   — Google Gemini
#   /xai      — xAI Grok  (alias: /grok)
#   /local    — clear the override, back to primary
#   /route    — show which provider this chat is currently using
#
# Overrides are scoped to the session (Telegram chat_id / Slack channel_id);
# other chats, system paths (evals, benchmarks, smoke tests), and SENTINEL
# are unaffected.
#
# Requires the target provider's API key in the environment (e.g.
# ANTHROPIC_API_KEY for /claude). Add the key to ~/.config/prometheus/env
# and restart the daemon.
router:
  overrides:
    enabled: true          # direct-mode commands are active
    sticky: true           # overrides persist until /local (false = one-shot)

# Phase 3 — opt-in cloud escalation for failed tool calls.
#
# When a tool call fails validation more times than the adapter's max_retries,
# the main agent normally aborts. With escalation enabled, the retry engine
# instead spawns a subagent running on a stronger provider (e.g. Claude,
# GPT, Grok) to attempt the same tool call, and feeds the result back as a
# tool_result. The main agent keeps running on the primary provider — only
# the single failing tool call is delegated.
#
# Default: disabled. Uncomment and fill in an api_key_env to enable.
#
# router:
#   escalation:
#     enabled: false
#     provider:
#       provider: anthropic            # anthropic | openai | gemini | xai
#       api_key_env: ANTHROPIC_API_KEY
#       model: claude-sonnet-4-6
#     as_subagent: true                # use isolated SubagentSpawner (recommended)
#     budget_usd: 1.00                 # soft cost cap per escalation (future enforcement)

divergence:
  enabled: false

learning:
  periodic_nudge_interval: 15
  auto_skill_creation: true

sentinel:
  enabled: false
  idle_threshold_minutes: 15
  dream_interval_minutes: 30

web:
  enabled: false
  api_port: 8005
  ws_port: 8010

lsp:
  enabled: false

profiles:
  default: "full"
  custom_dir: "~/.prometheus/profiles"

anatomy:
  enabled: true
  scan_on_startup: true

mcp_servers: {}

evals:
  results_dir: "~/.prometheus/eval_results"
  skip_network_tasks: true

tracing:
  enabled: false
