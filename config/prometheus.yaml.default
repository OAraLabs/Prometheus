# Prometheus configuration — reference defaults
# Copy to config/prometheus.yaml and customize (or run `prometheus setup`).
# config/prometheus.yaml is gitignored — your secrets stay local.
#
# CONFIG SEARCH ORDER (first hit wins):
#   1. an explicit --config path
#   2. config/prometheus.yaml          — repo-local (checkout installs)
#   3. $PROMETHEUS_CONFIG_DIR/prometheus.yaml
#      (default ~/.prometheus/prometheus.yaml — pip installs; this is
#       what `prometheus setup --fast` writes)
#
# SECRETS never belong in this file — put them in the env file the daemon
# and the systemd unit both load: ~/.config/prometheus/env
# (PROMETHEUS_API_TOKEN, PROMETHEUS_TELEGRAM_TOKEN, ANTHROPIC_API_KEY, …).

system:
  name: "Prometheus"
  version: "0.1.0"

# Layer 1 Bootstrap — identity files loaded into every system prompt
bootstrap:
  load_soul: true       # ~/.prometheus/SOUL.md
  load_agents: true     # ~/.prometheus/AGENTS.md

model:
  provider: "llama_cpp"             # llama_cpp, ollama, openai, anthropic, gemini, xai,
                                    # deepseek, kimi, glm, mimo
  base_url: "http://localhost:8080" # Inference server URL
  model: ""                         # Auto-detected from server if blank
  grammar_enforcement: true             # GBNF constrained decoding for llama.cpp tool calls
  # suppress_thinking: true             # UNSET defaults to true: send chat_template_kwargs.thinking=false
                                        # every turn so the model's reasoning channel stays OFF (keeps
                                        # gemma4-26b from burning its budget thinking + emitting empty
                                        # content). Set false to ENABLE thinking on agent turns — only
                                        # with a server-side llama.cpp --reasoning-budget in place, or
                                        # unbounded thinking can exhaust the budget. (2026-06-11 bakeoff:
                                        # the openhands arm ran thinking-on; this knob lets Prometheus match.)
  max_tool_iterations: 25               # Max tool calls per user message before hard stop (local/llama)
  max_tool_iterations_cloud: 50         # Separate cap for cloud (tier=off): Claude plans multi-step sequences local models wouldn't
  fallback_provider: "ollama"
  fallback_url: "http://localhost:11434"

# Assembly-time context compaction (the relief valve). Sprint 2 (OAra):
# this was config-dark since birth — the compactor only exists when
# compaction.enabled is true. Default ON; the config-dark audit alarms if
# an expected-enabled compactor is missing from /api/status.
compaction:
  enabled: true

context:
  effective_limit: 24000
  compression_trigger: 0.75
  tool_result_max: 4000
  tool_results_turn_budget: 8000            # max tokens across all results per turn
  reserved_output: 2000
  fresh_tail_count: 32
  microcompact_after_turns: 3               # compact tool results older than N turns
  microcompact_keep_chars: 200
  microcompact_keep_chars_no_lcm: 500

tools:
  deferred_loading:
    enabled: false                          # all tool schemas in prompt by default
    always_loaded: [bash, task_create, read_file, write_file, edit_file, grep, glob, tool_search]
    mcp_always_deferred: true
    search_mcp: true

adapter:
  adaptive_strictness: false                # auto-tune per-tool strictness from telemetry
  strictness_window: 100
  strictness_threshold: 0.8

security:
  permission_mode: "default"
  workspace_root: "~"
  denied_commands:
    - "rm -rf /"
    - "rm -rf ~"
    - "DROP TABLE"
    - "mkfs"
  denied_paths:
    - "/etc"
    - "/sys"
    - "/boot"
    - "~/.ssh"
    - "config/prometheus.yaml"
  # Regexes auto-ALLOWed even at SYSTEM trust (background tasks / cron) so a
  # vetted long-running job can run without a human approver. Evaluated AFTER
  # the denied/always-blocked/exfiltration gates (cannot resurrect a block) and
  # refused if the command contains chaining metachars (; & | ` $()). Keep each
  # pattern as narrow as possible — anchor the host, the destination, and the
  # source. Example: download ONE Hugging Face .gguf onto the GPU box's models
  # dir (powers the download-model-to-gpu skill). Replace the login with yours.
  # allowed_commands:
  #   - ^ssh\s+<user>@<gpu-host>\s+'wget\s+[^']*-O\s+~/models/[^']*\.gguf\s+https://huggingface\.co/[^']*\.gguf'\s*$
  audit:
    enabled: true
    retention_days: 30
  exfiltration:
    enabled: true
  approval_queue:
    enabled: false
    timeout_seconds: 300

infrastructure:
  archive_enabled: true
  telemetry_enabled: true

gateway:
  telegram_enabled: false
  telegram_token: ""                # Set via PROMETHEUS_TELEGRAM_TOKEN env var
  allowed_chat_ids: []
  proxy_url: null
  heartbeat_interval: 30
  cron_enabled: true
  # Sprint S1: user-visible signals (skill_created / skill_refined /
  # memory_updated / curator_report) post a short notification to the
  # last active Telegram chat. Modes: off | quiet | verbose.
  # `/notifications <mode>` toggles at runtime (Stream 3).
  skill_event_notifications: quiet
  media:
    max_file_size_mb: 20
    cache_dir: "~/.prometheus/cache/media"
  rate_limits:
    messages_per_minute: 30
    media_downloads_per_minute: 10
  # Slack gateway (optional extra: pip install 'oara-prometheus[slack]').
  # Socket Mode — needs BOTH tokens: a bot token (xoxb-...) and an app-level
  # token (xapp-...), created at https://api.slack.com/apps. Empty
  # allowed_channels = respond anywhere the bot is invited. (The legacy flat
  # keys slack_enabled / slack_bot_token / slack_app_token / slack_channels
  # still work and win over this nested form when set.)
  slack:
    enabled: false
    bot_token: ""                     # Set via PROMETHEUS_SLACK_BOT_TOKEN env var
    app_token: ""                     # Set via PROMETHEUS_SLACK_APP_TOKEN env var
    allowed_channels: []              # e.g. [C0123456789]

  # SPRINT G2: Discord gateway (optional extra: pip install 'oara-prometheus[discord]').
  # Whitelist semantics: DMs are ALWAYS allowed; guild-channel messages need
  # a channel_ids (per-channel) or guild_ids (whole-guild) hit. With both
  # empty the bot is DMs-only. App commands register guild-scoped (instant)
  # when guild_ids is set, else globally (up to ~1h to propagate Discord-side).
  discord:
    enabled: false
    token: ""                          # Set via PROMETHEUS_DISCORD_TOKEN env var
    guild_ids: []                      # e.g. [123456789012345678]
    channel_ids: []                    # e.g. [987654321098765432]
    skill_event_notifications: quiet   # off | quiet | verbose
    long_reply_threshold: 800          # chars; longer replies open a thread

whisper:
  enabled: false
  model: "base"
  device: "auto"
  language: "en"

model_router:
  enabled: false

# Sprint 22 GRAFT-ROUTER-WIRE Phase 4 — direct-mode provider overrides.
#
# Lets you switch a single Telegram (or Slack) chat to a different cloud
# provider on the fly:
#   /claude   — route this chat through Anthropic Claude
#   /gpt      — OpenAI GPT
#   /gemini   — Google Gemini
#   /xai      — xAI Grok  (alias: /grok)
#   /local    — clear the override, back to primary
#   /route    — show which provider this chat is currently using
#
# Overrides are scoped to the session (Telegram chat_id / Slack channel_id);
# other chats, system paths (evals, benchmarks, smoke tests), and SENTINEL
# are unaffected.
#
# Requires the target provider's API key in the environment (e.g.
# ANTHROPIC_API_KEY for /claude). Add the key to ~/.config/prometheus/env
# and restart the daemon.
router:
  overrides:
    enabled: true          # direct-mode commands are active
    sticky: true           # overrides persist until /local (false = one-shot)

# Per-slash-command model selection.
#
# Each /claude /gpt /gemini /xai command in Telegram (and /grok as a /xai
# alias) uses the provider + model below. If you omit this section, or omit
# a specific command, the daemon falls back to the built-in default
# (logged as WARN once at first use) — the defaults are conservative
# (cheap/fast) and listed in src/prometheus/router/model_router.py
# under OVERRIDE_PRESETS.
#
# Model field accepts either a provider alias (e.g. claude-sonnet-4-5,
# claude-haiku-4-5) or a fully pinned snapshot ID
# (claude-sonnet-4-5-20250929). Anthropic pre-4.6 aliases resolve
# server-side; 4.6+ IDs are already dateless pinned snapshots. For
# OpenAI / Gemini / xAI use the model name the provider exposes
# (e.g. gpt-4o, gemini-2.5-pro, grok-4.5).
#
# After editing, restart the daemon and grep journalctl for "slash_commands"
# to verify the wiring:
#   journalctl --user -u prometheus.service | grep slash_commands
slash_commands:
  claude:
    provider: anthropic
    api_key_env: ANTHROPIC_API_KEY
    model: claude-haiku-4-5    # cheap + fast default; user pins heavier model
  gpt:
    provider: openai
    api_key_env: OPENAI_API_KEY
    model: gpt-4o
  gemini:
    provider: gemini
    api_key_env: GEMINI_API_KEY
    model: gemini-2.5-flash
  xai:
    provider: xai
    api_key_env: XAI_API_KEY
    model: grok-4.5    # request EXPLICITLY: grok-3/grok-4 aliases serve grok-4.3
  # CLOUD EXPANSION (2026-07) — /deepseek /kimi /glm /mimo. Same rules as
  # above: the command only works once the key env var is in
  # ~/.config/prometheus/env and the daemon has been restarted.
  deepseek:
    provider: deepseek
    api_key_env: DEEPSEEK_API_KEY
    model: deepseek-v4-flash   # reasoning flagship: deepseek-v4-pro
                               # (deepseek-chat/-reasoner aliases deprecated 2026-07-24)
  kimi:
    provider: kimi
    api_key_env: MOONSHOT_API_KEY
    model: kimi-k2.6
  glm:
    provider: glm
    api_key_env: ZAI_API_KEY
    model: glm-5.2
  mimo:
    provider: mimo
    api_key_env: MIMO_API_KEY
    model: mimo-v2.5-pro

# Phase 3 — opt-in cloud escalation for failed tool calls.
#
# When a tool call fails validation more times than the adapter's max_retries,
# the main agent normally aborts. With escalation enabled, the retry engine
# instead spawns a subagent running on a stronger provider (e.g. Claude,
# GPT, Grok) to attempt the same tool call, and feeds the result back as a
# tool_result. The main agent keeps running on the primary provider — only
# the single failing tool call is delegated.
#
# Default: disabled. Uncomment and fill in an api_key_env to enable.
#
# router:
#   escalation:
#     enabled: false
#     provider:
#       provider: anthropic            # anthropic | openai | gemini | xai
#       api_key_env: ANTHROPIC_API_KEY
#       model: claude-sonnet-4-6
#     as_subagent: true                # use isolated SubagentSpawner (recommended)
#     budget_usd: 1.00                 # soft cost cap per escalation (future enforcement)

divergence:
  enabled: false

learning:
  # PeriodicNudge — self-reflection prompt every N agent turns.
  nudge_enabled: true
  nudge_interval: 15
  # SkillCreator — auto-generate SKILL.md from successful tool traces.
  auto_skill_creation: true
  skill_min_tool_calls: 3
  # SkillRefiner — refine an existing auto-skill when execution deviates beneficially.
  skill_refinement_enabled: false
  skill_refiner_model: default
  # Curator — periodic consolidation pass over ~/.prometheus/skills/auto/.
  # Stage 1 (auto): flip lifecycle state based on mtime (stale/archived).
  # Stage 2 (LLM): recommend consolidations (report-only) + prunings (applied:
  # file moved to auto/.archive/, NEVER deleted). Pinned skills are protected.
  # Adapted from Hermes agent/curator.py (see prometheus/learning/curator.py).
  curator_enabled: true
  curator_interval_seconds: 604800        # 7 days
  curator_stale_after_days: 30            # mtime >= N days → state=stale
  curator_archive_after_days: 90          # mtime >= N days → state=archived
  curator_min_idle_seconds: 0             # 0 = always run on tick (reserved)
  curator_max_prunings_per_run: 10        # safety cap on auto-archives per pass
  curator_telegram_summary: true          # post a one-line summary to Telegram on run
  # GEPA (SUNRISE Session B) — Generalized Evolutionary Prompt Architecture.
  gepa_enabled: false
  gepa_max_skills_per_cycle: 3
  gepa_variants_per_skill: 3
  gepa_min_traces_required: 10
  gepa_judge_threshold: 0.7
  gepa_min_idle_minutes: 10
  gepa_max_frequency_hours: 24
  gepa_model: default

trajectory_export:
  enabled: false
  interval_seconds: 86400  # 24h
  nightly_limit: 1000
  output_dir: "~/.prometheus/trajectories/"
  format: jsonl

symbiote:
  enabled: false                # GRAFT-SYMBIOTE Session A: scout/harvest/graft pipeline
  github_token: null            # Or set via env: PROMETHEUS_GITHUB_TOKEN (never logged)
  language_default: Python
  min_stars_default: 10
  max_repo_size_mb: 100
  file_budget_max: 15
  file_budget_kb: 50
  clone_timeout_seconds: 60
  sandbox_dir: "~/.prometheus/symbiote/sandbox/"
  harvest_dir: "~/.prometheus/symbiote/harvests/"
  sessions_db: "~/.prometheus/symbiote/sessions.db"
  scout_model: default          # Model for query gen + relevance scoring
  harvest_model: default        # Model for file selection + adaptation plan
  # GRAFT-SYMBIOTE Session B: blue-green hot swap with auto-rollback
  morph:
    enabled: false              # Off by default; opt-in per machine
    health_check_timeout_seconds: 60
    health_check_interval_seconds: 5
    consecutive_passes_required: 3
    auto_rollback: true         # Always true in V1 (not configurable)
    daemon_manager: auto        # auto | systemd | pidfile | pkill
    daemon_health_url: null     # Optional HTTP /health endpoint to ping
    candidate_dir: "~/.prometheus/symbiote/candidate/"
    post_mortem_dir: "~/.prometheus/symbiote/post_mortem/"
  backup:
    enabled: true               # BackupVault is independently useful
    vault_root: "~/.prometheus/symbiote/backups"
    max_backups: 10
    include_identity: true      # Backup SOUL.md, AGENTS.md, ANATOMY.md
    include_config: true        # Backup config/prometheus.yaml
    pre_graft_backup: false     # Auto-backup before any graft (off by default)
    exempt_from_retention:
      - symbiote_morph
      - manual
      - pre_restore

sentinel:
  enabled: false
  idle_threshold_minutes: 15
  dream_interval_minutes: 30

# Beacon dashboard + REST/WS control plane. ON by default (Onboarding
# Phase 0): the daemon mints a PROMETHEUS_API_TOKEN into the env file on
# first start if none is set, so on-by-default is not open-by-default.
# Set an explicit empty PROMETHEUS_API_TOKEN= in the env file to run
# deliberately open (localhost-only recommended).
web:
  enabled: true
  api_port: 8005
  ws_port: 8010

# Image generation — the image_generate tool's backend selection + per-backend
# settings. CLOUD EXPANSION (2026-07) adds the PAID DashScope backend (WAN 2.5).
#
# HARD RULE: `auto` NEVER silently selects the paid API. auto = probe local
# ComfyUI, fall back to free Pollinations. DashScope runs ONLY when the agent
# passes backend=dashscope explicitly, or when you deliberately set
# default_backend: dashscope below.
image_generation:
  default_backend: auto              # auto | pollinations | comfyui | dashscope
  comfyui:
    base_url: "http://127.0.0.1:8188"
    default_model: "flux1-schnell-fp8.safetensors"
    default_steps: 4
  # WAN 2.5 text-to-image via Alibaba DashScope (async task API; PAID).
  # Key: DASHSCOPE_API_KEY in ~/.config/prometheus/env
  # (console: https://dashscope.console.aliyun.com / modelstudio intl).
  dashscope:
    api_key_env: DASHSCOPE_API_KEY
    model: "wan2.5-t2i-preview"
    # Legacy-but-working international default. Newer workspace-scoped
    # DashScope domains exist — override here if your account uses one.
    base_url: "https://dashscope-intl.aliyuncs.com/api/v1"

# Video generation — the video_generate tool (Kling 3.0). PAID; dormant until
# both keys are set. Auth is an AccessKey+SecretKey pair; the tool self-signs
# a short-lived JWT (HS256) per request — keys never leave this machine.
# Console: https://app.klingai.com (API access).
video_generation:
  kling:
    access_key_env: KLING_ACCESS_KEY
    secret_key_env: KLING_SECRET_KEY
    base_url: "https://api-singapore.klingai.com"
    model_name: "kling-v3"
    poll_budget_seconds: 600           # videos take MINUTES; poll every ~10s

# Core web research tools — web_fetch, web_search, youtube_transcript, download_file
web_tools:
  fetch_timeout_seconds: 30                 # web_fetch HTTP timeout
  fetch_max_chars: 8000                     # web_fetch default truncation limit
  search_max_results: 8                     # web_search default result count
  download_dir: "~/.prometheus/downloads"   # download_file default destination
  download_max_mb: 100                      # download_file size cap (MB)
  youtube_transcript_language: "en"         # youtube_transcript default language code

# Printing Press CLI library — discover and install Go-based service CLIs
# from a local clone of github.com/mvanhorn/printing-press-library
printing_press:
  enabled: false                            # opt-in
  library_path: null                        # auto-detect ~/printing-press-library/ → /tmp/printing-press-library/
  auto_suggest: true                        # suggest install on `command not found` (user-initiated only)
  auto_update_library: false                # git pull library on daemon startup

lsp:
  enabled: false

profiles:
  default: "full"
  custom_dir: "~/.prometheus/profiles"

anatomy:
  enabled: true
  scan_on_startup: true

mcp_servers: {}

# H3: lifecycle hooks. Empty by default (no hooks run). Each event maps to a
# list of hook definitions; supported types: command, http, prompt, agent.
# Example:
#   hooks:
#     pre_tool_use:
#       - type: command
#         command: "echo checking $ARGUMENTS"   # $ARGUMENTS = JSON payload
#         block_on_failure: false               # true = a nonzero exit blocks the tool
#     post_tool_use:
#       - type: http
#         url: "http://localhost:9090/hook"
hooks: {}

evals:
  results_dir: "~/.prometheus/eval_results"
  skip_network_tasks: true

tracing:
  enabled: false
